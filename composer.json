{
    "name": "erikr/auth",
    "description": "Shared auth, session, CSRF, logging and mailer library",
    "type": "library",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^7.0",
        "chillerlan/php-qrcode": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "files": [
            "src/log.php",
            "src/csrf.php",
            "src/auth.php",
            "src/mailer.php",
            "src/mail_template.php",
            "src/mail_helpers.php",
            "src/invite.php",
            "src/tokens.php",
            "src/admin.php",
            "src/totp.php",
            "src/avatar.php",
            "src/remember.php",
            "src/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ErikR\\Auth\\Tests\\": "tests/"
        }
    }
}
